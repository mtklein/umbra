# Umbra C style — see AGENTS.md for rationale.
#
# Known limitations:
#   - Manual alignment of struct fields / related declarations is
#     not preserved; AlignConsecutiveDeclarations over-aligns.

Language: Cpp
ColumnLimit: 90

# Indentation: 4 spaces, no tabs
IndentWidth: 4
ContinuationIndentWidth: 4
UseTab: Never
IndentCaseLabels: false
IndentCaseBlocks: false
IndentPPDirectives: None

# K&R braces
BreakBeforeBraces: Attach

# East const: int const x, never const int
QualifierAlignment: Custom
QualifierOrder: ['type', 'const', 'volatile']

# One-liners: short functions, blocks, ifs, cases on one line
AllowShortFunctionsOnASingleLine: All
AllowShortBlocksOnASingleLine: Always
AllowShortIfStatementsOnASingleLine: AllIfsAndElse
AllowShortLoopsOnASingleLine: true
AllowShortCaseLabelsOnASingleLine: true
AllowShortEnumsOnASingleLine: true

# Pointer: int *p (star with name)
PointerAlignment: Right

# Spaces
SpaceAfterCStyleCast: false
SpaceBeforeParens: ControlStatements
SpaceBeforeAssignmentOperators: true
SpaceInEmptyBlock: false
SpacesInParens: Never
BitFieldColonSpacing: Both

# Bin-pack arguments for density
BinPackArguments: true
BinPackParameters: true
AlignAfterOpenBracket: Align

# Binary operators wrap before, not after; one || per line
BreakBeforeBinaryOperators: NonAssignment
BreakBinaryOperations: RespectPrecedence
AlignOperands: DontAlign

# Don't auto-align — manual alignment is intentional
AlignConsecutiveAssignments: None
AlignConsecutiveDeclarations: None
AlignConsecutiveMacros: None
AlignEscapedNewlines: Left
AlignTrailingComments:
  Kind: Always
  OverEmptyLines: 0

# Keep return type on same line as function name
AlwaysBreakAfterReturnType: None
PenaltyReturnTypeOnItsOwnLine: 1000
PenaltyBreakBeforeFirstCallParameter: 200
PenaltyBreakAssignment: 25
PenaltyExcessCharacter: 10

# Includes: don't reorder
SortIncludes: Never
IncludeBlocks: Preserve

# Blank lines
MaxEmptyLinesToKeep: 1
KeepEmptyLinesAtTheStartOfBlocks: false
SeparateDefinitionBlocks: Leave

# Braced init lists: compact
Cpp11BracedListStyle: true
SpaceBeforeCpp11BracedList: false
