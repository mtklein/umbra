{
  "hooks": {
    "PreCommit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ninja && [ \"$(ninja 2>&1)\" = \"ninja: no work to do.\" ] && git diff --quiet -- dumps/",
            "timeout": 120,
            "statusMessage": "Running ninja (build + no-op check)..."
          }
        ]
      }
    ]
  }
}
