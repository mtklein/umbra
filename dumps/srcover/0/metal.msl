    float v20 = as_type<float>(v1) - v13;
    float v21 = fma(v19, v20, v11);
    float v22 = (float)as_type<half>((ushort)v16);
    float v23 = fma(v22, v20, v12);
    float v24 = (float)as_type<half>((ushort)v17);
    float v25 = fma(v24, v20, v13);
    uint v26 = (uint)as_type<ushort>((half)v21);
    p2[y * m.stride2 + x] = (ushort)v26;

