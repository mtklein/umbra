) {
    if (pos.x >= m.w) return;
    uint x = m.x0 + pos.x;
    uint y = m.y0 + pos.y;
    uint v0 = 0u;
    uint v1 = 1065353216u;
    uint v2 = p0[y * m.stride0 + x];
    uint v3 = v2 >> 8u;
    uint v4 = v3 & 255u;
    float v5 = (float)(int)v4;
    uint v6 = v2 >> 16u;
    uint v7 = v6 & 255u;
    float v8 = (float)(int)v7;
