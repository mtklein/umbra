    float v25 = (float)(int)v24;
    float v26 = fma(-1.0f, as_type<float>(v2), v25);
    float v27 = fma(v26, v26, 0.0f);
    float v28 = fma(v23, v23, v27);
    uint v29 = as_type<uint>(v28) >> v5;
    uint v30 = v4 - v29;
    uint v31 = as_type<float>(v0) == v28 ? 0xffffffffu : 0u;
    float v32 = fma(as_type<float>(v30), as_type<float>(v30), 0.0f);
    float v33 = fma(-v28, v32, as_type<float>(v6));
    float v34 = fma(v33, v33, 0.0f);
    float v35 = fma(as_type<float>(v8), v34, 0.0f);
    float v36 = fma(as_type<float>(v7), v33, v35);
    float v37 = fma(1.0f, as_type<float>(v6), v36);
    float v38 = fma(as_type<float>(v30), v37, 0.0f);
    float v39 = fma(as_type<float>(v7), v38, 0.0f);
    float v40 = fma(v28, v38, 0.0f);
    float v41 = fma(-v40, v40, v28);
    float v42 = fma(v41, v39, 0.0f);
    float v43 = fma(v28, v38, v42);
    uint v44 = (v31 != 0u) ? v0 : as_type<uint>(v43);
    float v45 = fma(as_type<float>(v3), as_type<float>(v44), 0.0f);
    float v46 = max(as_type<float>(v0), v45);
    float v47 = min(as_type<float>(v6), v46);
    float v48 = fma(v47, v20, as_type<float>(v12));
    float v49 = fma(v47, v17, as_type<float>(v9));
    float v50 = fma(v47, v18, as_type<float>(v10));
    float v51 = fma(v47, v19, as_type<float>(v11));
    uint v52 = (uint)as_type<ushort>((half)v48);
    uint v53 = (uint)as_type<ushort>((half)v51);
    uint v54 = (uint)as_type<ushort>((half)v50);
    uint v55 = (uint)as_type<ushort>((half)v49);
    p0[y * m.stride0 + x] = half4(as_type<half>((ushort)v55), as_type<half>((ushort)v54), as_type<half>((ushort)v53), as_type<half>((ushort)v52));
}
