    if (pos.x >= m.w) return;
    uint x = m.x0 + pos.x;
    uint y = m.y0 + pos.y;
    uint v0 = 0u;
    uint v1 = p1[0];
    uint v2 = p1[1];
    uint v3 = p1[2];
    uint v4 = 1597463007u;
    uint v5 = 1u;
    uint v6 = 1065353216u;
    uint v7 = 1056964608u;
    uint v8 = 1052770304u;
    uint v9 = p2[4];
    uint v10 = p2[5];
    uint v11 = p2[6];
    uint v12 = p2[7];
    uint v13 = p2[8];
    uint v14 = p2[9];
    uint v15 = p2[10];
    uint v16 = p2[11];
    float v17 = fma(-1.0f, as_type<float>(v9), as_type<float>(v13));
    float v18 = fma(-1.0f, as_type<float>(v10), as_type<float>(v14));
    float v19 = fma(-1.0f, as_type<float>(v11), as_type<float>(v15));
