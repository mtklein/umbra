    float v13 = v12 + as_type<float>(v5);
    float v14 = fma(as_type<float>(v3), v13, as_type<float>(v1));
    uint v15 = m.y0 + pos.y;
    float v16 = (float)(int)v15;
    float v17 = v16 + as_type<float>(v5);
    float v18 = fma(as_type<float>(v4), v17, as_type<float>(v2));
    float v19 = v18 * as_type<float>(v9);
    float v20 = fma(as_type<float>(v4), v16, as_type<float>(v2));
    float v21 = v20 * as_type<float>(v9);
    float v22 = max(v21, v19);
