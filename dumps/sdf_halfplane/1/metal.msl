    float v24 = min(v21, v19);
    float v25 = fma(v14, as_type<float>(v8), v24);
    float v26 = fma(as_type<float>(v3), v12, as_type<float>(v1));
    float v27 = fma(v26, as_type<float>(v8), v22);
    float v28 = max(v27, v23);
    float v29 = v28 - as_type<float>(v10);
    uint v30 = v29 <  as_type<float>(v0) ? 0xffffffffu : 0u;
    float v31 = fma(v26, as_type<float>(v8), v24);
    float v32 = min(v31, v25);
    float v33 = v32 - as_type<float>(v10);
    uint v34 = v33 <  as_type<float>(v0) ? 0xffffffffu : 0u;
    uint v35 = (v34 != 0u) ? v6 : v0;
    uint v36 = (v30 != 0u) ? v7 : v35;
    p0[y * m.stride0 + x] = (uchar)v36;
