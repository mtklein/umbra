    if (pos.x >= m.w) return;
    uint x = m.x0 + pos.x;
    uint y = m.y0 + pos.y;
    uint v0 = 0u;
    uint v1 = p1[0];
    uint v2 = p1[1];
    uint v3 = p1[2];
    uint v4 = p1[3];
    uint v5 = 1u;
    uint v6 = 2u;
    uint v7 = p2[0];
    uint v8 = p2[1];
    uint v9 = p2[2];
    uint v10 = p2[3];
    uint v11 = p2[4];
    uint v12 = p2[5];
    float v13 = as_type<float>(v0) - as_type<float>(v9);
    float v14 = as_type<float>(v0) - as_type<float>(v12);
    float v15 = as_type<float>(v0) - v14;
    uint v16 = m.x0 + pos.x;
    float v17 = (float)(int)v16;
    float v18 = v17 + as_type<float>(1065353216u);
    float v19 = fma(as_type<float>(v3), v17, as_type<float>(v1));
    float v20 = v19 - as_type<float>(v10);
    float v21 = v20 * v20;
    uint v22 = m.y0 + pos.y;
    float v23 = (float)(int)v22;
    float v24 = v23 + as_type<float>(1065353216u);
    float v25 = fma(as_type<float>(v4), v24, as_type<float>(v2));
    float v26 = v25 - as_type<float>(v11);
    float v27 = v25 - as_type<float>(v8);
    float v28 = v27 * v27;
    float v29 = v26 * v26;
    float v30 = fma(as_type<float>(v4), v23, as_type<float>(v2));
    float v31 = v30 - as_type<float>(v11);
    float v32 = v31 * v31;
    float v33 = max(v32, v29);
    float v34 = fma(as_type<float>(v3), v18, as_type<float>(v1));
    float v35 = v34 - as_type<float>(v10);
    float v36 = v34 - as_type<float>(v7);
    float v37 = v35 * v35;
    float v38 = max(v21, v37);
