    float v40 = precise::sqrt(v39);
    float v41 = v40 - as_type<float>(v12);
    float v42 = as_type<float>(v0) - v41;
    float v43 = max(v13, v42);
    float v44 = v36 * v36;
    uint v45 = v43 <  as_type<float>(0u) ? 0xffffffffu : 0u;
    float v46 = v19 - as_type<float>(v7);
    float v47 = v46 * v46;
    float v48 = max(v47, v44);
    float v49 = v30 - as_type<float>(v8);
    float v50 = v49 * v49;
    float v51 = max(v50, v28);
    float v52 = v48 + v51;
    float v53 = precise::sqrt(v52);
    float v54 = v53 - as_type<float>(v9);
    float v55 = max(v54, v15);
    uint v56 = v55 <  as_type<float>(0u) ? 0xffffffffu : 0u;
    uint v57 = (v45 != 0u) ? v5 : v0;
    uint v58 = (v56 != 0u) ? v6 : v57;
    uint v59 = (uint)(ushort)v58;
    p0[y * m.stride0 + x] = (ushort)v59;
