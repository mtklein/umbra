# Cross-compilation only: build but don't run (x86_64/x86_64h can't execute on ARM host).
build $out/umbra.o:   compile umbra.c
build $out/vm.o:      compile vm.c
build $out/test.o:    compile test.c
build $out/vm_test.o: compile vm_test.c

build $out/test:      link $out/test.o $out/umbra.o $out/vm.o
build $out/vm_test:   link $out/vm_test.o $out/vm.o
