      dumps/sdf_circle/0/ir.txt $
      dumps/sdf_circle/0/builder.txt $
      dumps/sdf_circle/0/metal.msl $
      dumps/sdf_circle/0/vulkan.spirv $
      dumps/sdf_circle/0/vulkan.msl $
