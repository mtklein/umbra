x86 = $builddir/x86_xsan

build $out/coverage.profdata: profmerge | $
      $out/test_0.log $
      $x86/test_0.log $
      $out/test_1.log $
      $x86/test_1.log $
      $out/test_2.log $
      $x86/test_2.log $
      $out/dump.log $
      $x86/dump.log
    dir = $out $x86

build $out/coverage.txt: cov_report $out/coverage.profdata | $
      $out/test $
      $out/dump $
      $x86/test $
      $x86/dump
    objects = $out/test $
              -object=$out/dump $
              -object=$x86/test $
              -object=$x86/dump

build $out/report.txt: cov_show $out/coverage.profdata | $
      $out/test $
      $out/dump $
      $x86/test $
      $x86/dump
    objects = $out/test $
              -object=$out/dump $
              -object=$x86/test $
              -object=$x86/dump
    dir = $out/report
