cov = -fprofile-instr-generate -fcoverage-mapping

out     = $builddir/xsan
cc      = $clang -fsanitize=address,integer,undefined -fno-sanitize-recover=all $cov
exec    = env UBSAN_OPTIONS=print_stacktrace=1 LLVM_PROFILE_FILE=$builddir/xsan/%p.profraw
ldflags = -framework Metal -framework Foundation -L/opt/homebrew/lib -lMoltenVK -lwgpu_native $cov
include build/project.ninja

build $out/tools/demo.o: compile tools/demo.c
    cflags = -I/opt/homebrew/include -Wno-cast-align
build $out/tools/work_group.o: compile tools/work_group.c
build $out/demo:   link $out/tools/demo.o $out/tools/work_group.o $out/src/builder.o $out/src/flat_ir.o $out/src/op.o $out/src/fingerprint.o $out/src/dispatch_overlap.o $out/src/gpu_buf_cache.o $out/src/hash.o $out/src/uniforms.o $out/src/uniform_ring.o $out/src/ra.o $out/src/interpreter.o $out/src/jit.o $out/src/jit_arm64.o $out/src/jit_x86.o $out/src/asm_arm64.o $out/src/asm_x86.o $out/src/metal.o $out/src/spirv.o $out/src/vulkan.o $out/src/wgpu.o $out/src/draw.o $out/stb_truetype.o $out/stb_image_write.o $out/slides/slides.o $out/slides/solid.o $out/slides/text.o $out/slides/persp.o $out/slides/gradient.o $out/slides/slug.o $out/slides/anim.o $out/slides/overview.o $out/slides/swatch.o
    ldflags = -framework Metal -framework Foundation -L/opt/homebrew/lib -lSDL3 -lMoltenVK -lwgpu_native

build $out/dump.log | $
      dumps/srcover/arm64.txt $
      dumps/srcover/ir.txt $
      dumps/srcover/builder.txt $
      dumps/srcover/metal.msl $
      dumps/srcover/vulkan.spirv $
      dumps/srcover/vulkan.msl $
      dumps/slug_two_pass/acc/arm64.txt $
      dumps/slug_two_pass/acc/ir.txt $
      dumps/slug_two_pass/acc/builder.txt $
      dumps/slug_two_pass/acc/metal.msl $
      dumps/slug_two_pass/acc/vulkan.spirv $
      dumps/slug_two_pass/acc/vulkan.msl $
      dumps/slug_two_pass/draw/arm64.txt $
      dumps/slug_two_pass/draw/ir.txt $
      dumps/slug_two_pass/draw/builder.txt $
      dumps/slug_two_pass/draw/metal.msl $
      dumps/slug_two_pass/draw/vulkan.spirv $
      dumps/slug_two_pass/draw/vulkan.msl $
      dumps/solid_fill_src/arm64.txt $
      dumps/solid_fill_src/ir.txt $
      dumps/solid_fill_src/builder.txt $
      dumps/solid_fill_src/metal.msl $
      dumps/solid_fill_src/vulkan.spirv $
      dumps/solid_fill_src/vulkan.msl $
      dumps/source_over_srcover/arm64.txt $
      dumps/source_over_srcover/ir.txt $
      dumps/source_over_srcover/builder.txt $
      dumps/source_over_srcover/metal.msl $
      dumps/source_over_srcover/vulkan.spirv $
      dumps/source_over_srcover/vulkan.msl $
      dumps/destination_over_dstover/arm64.txt $
      dumps/destination_over_dstover/ir.txt $
      dumps/destination_over_dstover/builder.txt $
      dumps/destination_over_dstover/metal.msl $
      dumps/destination_over_dstover/vulkan.spirv $
      dumps/destination_over_dstover/vulkan.msl $
      dumps/multiply_blend/arm64.txt $
      dumps/multiply_blend/ir.txt $
      dumps/multiply_blend/builder.txt $
      dumps/multiply_blend/metal.msl $
      dumps/multiply_blend/vulkan.spirv $
      dumps/multiply_blend/vulkan.msl $
      dumps/full_coverage_no_rect_clip/arm64.txt $
      dumps/full_coverage_no_rect_clip/ir.txt $
      dumps/full_coverage_no_rect_clip/builder.txt $
      dumps/full_coverage_no_rect_clip/metal.msl $
      dumps/full_coverage_no_rect_clip/vulkan.spirv $
      dumps/full_coverage_no_rect_clip/vulkan.msl $
      dumps/no_blend_direct_paint/arm64.txt $
      dumps/no_blend_direct_paint/ir.txt $
      dumps/no_blend_direct_paint/builder.txt $
      dumps/no_blend_direct_paint/metal.msl $
      dumps/no_blend_direct_paint/vulkan.spirv $
      dumps/no_blend_direct_paint/vulkan.msl $
      dumps/text_8_bit_aa/arm64.txt $
      dumps/text_8_bit_aa/ir.txt $
      dumps/text_8_bit_aa/builder.txt $
      dumps/text_8_bit_aa/metal.msl $
      dumps/text_8_bit_aa/vulkan.spirv $
      dumps/text_8_bit_aa/vulkan.msl $
      dumps/text_sdf/arm64.txt $
      dumps/text_sdf/ir.txt $
      dumps/text_sdf/builder.txt $
      dumps/text_sdf/metal.msl $
      dumps/text_sdf/vulkan.spirv $
      dumps/text_sdf/vulkan.msl $
      dumps/perspective_text/arm64.txt $
      dumps/perspective_text/ir.txt $
      dumps/perspective_text/builder.txt $
      dumps/perspective_text/metal.msl $
      dumps/perspective_text/vulkan.spirv $
      dumps/perspective_text/vulkan.msl $
      dumps/linear_gradient_2_stop/arm64.txt $
      dumps/linear_gradient_2_stop/ir.txt $
      dumps/linear_gradient_2_stop/builder.txt $
      dumps/linear_gradient_2_stop/metal.msl $
      dumps/linear_gradient_2_stop/vulkan.spirv $
      dumps/linear_gradient_2_stop/vulkan.msl $
      dumps/radial_gradient_2_stop/arm64.txt $
      dumps/radial_gradient_2_stop/ir.txt $
      dumps/radial_gradient_2_stop/builder.txt $
      dumps/radial_gradient_2_stop/metal.msl $
      dumps/radial_gradient_2_stop/vulkan.spirv $
      dumps/radial_gradient_2_stop/vulkan.msl $
      dumps/linear_gradient_wide_gamut/arm64.txt $
      dumps/linear_gradient_wide_gamut/ir.txt $
      dumps/linear_gradient_wide_gamut/builder.txt $
      dumps/linear_gradient_wide_gamut/metal.msl $
      dumps/linear_gradient_wide_gamut/vulkan.spirv $
      dumps/linear_gradient_wide_gamut/vulkan.msl $
      dumps/radial_gradient_wide_gamut/arm64.txt $
      dumps/radial_gradient_wide_gamut/ir.txt $
      dumps/radial_gradient_wide_gamut/builder.txt $
      dumps/radial_gradient_wide_gamut/metal.msl $
      dumps/radial_gradient_wide_gamut/vulkan.spirv $
      dumps/radial_gradient_wide_gamut/vulkan.msl $
      dumps/linear_gradient_loop_stops/arm64.txt $
      dumps/linear_gradient_loop_stops/ir.txt $
      dumps/linear_gradient_loop_stops/builder.txt $
      dumps/linear_gradient_loop_stops/metal.msl $
      dumps/linear_gradient_loop_stops/vulkan.spirv $
      dumps/linear_gradient_loop_stops/vulkan.msl $
      dumps/radial_gradient_loop_stops/arm64.txt $
      dumps/radial_gradient_loop_stops/ir.txt $
      dumps/radial_gradient_loop_stops/builder.txt $
      dumps/radial_gradient_loop_stops/metal.msl $
      dumps/radial_gradient_loop_stops/vulkan.spirv $
      dumps/radial_gradient_loop_stops/vulkan.msl $
      dumps/slug_one_pass/arm64.txt $
      dumps/slug_one_pass/ir.txt $
      dumps/slug_one_pass/builder.txt $
      dumps/slug_one_pass/metal.msl $
      dumps/slug_one_pass/vulkan.spirv $
      dumps/slug_one_pass/vulkan.msl $
      dumps/animated_t_in_uniforms/arm64.txt $
      dumps/animated_t_in_uniforms/ir.txt $
      dumps/animated_t_in_uniforms/builder.txt $
      dumps/animated_t_in_uniforms/metal.msl $
      dumps/animated_t_in_uniforms/vulkan.spirv $
      dumps/animated_t_in_uniforms/vulkan.msl: run $out/dump

x86 = $builddir/x86_64h_xsan

build $out/coverage.profdata: profmerge | $
      $out/test.log $
      $out/dump.log $
      $x86/test.log $
      $x86/dump.log
    dir = $out $x86

build $out/coverage.txt: cov_report $out/coverage.profdata | $
      $out/test $
      $out/dump $
      $x86/test $
      $x86/dump
    objects = $out/test $
              -object=$out/dump $
              -object=$x86/test $
              -object=$x86/dump

build $out/report.txt: cov_show $out/coverage.profdata | $
      $out/test $
      $out/dump $
      $x86/test $
      $x86/dump
    objects = $out/test $
              -object=$out/dump $
              -object=$x86/test $
              -object=$x86/dump
    dir = $out/report
