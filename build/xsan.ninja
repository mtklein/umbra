      dumps/solid_fill_src/0/ir.txt $
      dumps/solid_fill_src/0/builder.txt $
      dumps/solid_fill_src/0/metal.msl $
      dumps/solid_fill_src/0/vulkan.spirv $
      dumps/solid_fill_src/0/vulkan.msl $
