      dumps/source_over_srcover/0/ir.txt $
      dumps/source_over_srcover/0/builder.txt $
      dumps/source_over_srcover/0/metal.msl $
      dumps/source_over_srcover/0/vulkan.spirv $
      dumps/source_over_srcover/0/vulkan.msl $
