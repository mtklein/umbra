      dumps/sdf_capsule/1/ir.txt $
      dumps/sdf_capsule/1/builder.txt $
      dumps/sdf_capsule/1/metal.msl $
      dumps/sdf_capsule/1/vulkan.spirv $
      dumps/sdf_capsule/1/vulkan.msl $
      dumps/sdf_capsule/1/wgpu.spirv $
      dumps/sdf_capsule/1/wgpu.msl $
