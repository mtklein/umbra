      dumps/coverage_null/0/ir.txt $
      dumps/coverage_null/0/builder.txt $
      dumps/coverage_null/0/metal.msl $
      dumps/coverage_null/0/vulkan.spirv $
      dumps/coverage_null/0/vulkan.msl $
