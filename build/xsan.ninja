      dumps/sdf_hexagon_n_gon/0/ir.txt $
      dumps/sdf_hexagon_n_gon/0/builder.txt $
      dumps/sdf_hexagon_n_gon/0/metal.msl $
      dumps/sdf_hexagon_n_gon/0/vulkan.spirv $
      dumps/sdf_hexagon_n_gon/0/vulkan.msl $
