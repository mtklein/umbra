out        = $builddir/host
cc         = $clang
frameworks = -framework Metal -framework Foundation
include build/project.ninja

build $out/dump.log | $
      dumps/srcover.bb $
      dumps/srcover.opt $
      dumps/srcover.c $
      dumps/srcover.arm64 $
      dumps/srcover.mca $
      dumps/srcover.metal: run $out/dump
